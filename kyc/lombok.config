# Module-scoped Lombok config. Lives inside the module so it is present in the
# Docker build context (which is the kyc/ directory), not just for local Gradle
# builds. Keep in sync with the repo-root lombok.config.
config.stopBubbling = true

# Copy Spring's @Qualifier and @Value onto the parameters of constructors
# generated by @RequiredArgsConstructor/@AllArgsConstructor. Without this,
# a field-level @Qualifier is silently dropped, so Spring cannot disambiguate
# when multiple beans of the same type exist (e.g. the WebClient beans
# KboWebClient and ProxyWebClient).
lombok.copyableAnnotations += org.springframework.beans.factory.annotation.Qualifier
lombok.copyableAnnotations += org.springframework.beans.factory.annotation.Value
